// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id        Int     @id @default(autoincrement())
  orderId   String  @unique // Внешний ID для LiqPay
  items     String  // JSON array
  amount    Float
  currency  String  @default("UAH")
  status    String  @default("pending") // pending, paid, failed, cancelled
  
  // Customer info
  customerName String?
  customerEmail String?
  customerPhone String?
  
  // Payment info
  liqpayOrderId String? @unique
  liqpayData    String?
  liqpaySignature String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([status])
  @@index([orderId])
}

model PaymentLog {
  id        Int     @id @default(autoincrement())
  orderId   String
  action    String  // webhook_received, signature_verified, status_updated, etc
  payload   String  // JSON
  timestamp DateTime @default(now())
  
  @@index([orderId])
  @@index([timestamp])
}
